# Copy this file to .env.local and fill in your values.
# .env.local is gitignored.

# Google OAuth Client ID for Drive sync (see docs/SETUP-DRIVE.md).
# This is a public identifier, NOT a secret — but we keep it in env to
# allow different IDs across dev / staging / prod environments.
VITE_GOOGLE_CLIENT_ID=

# Google API key for the Picker API (separate from OAuth client ID; see SETUP-DRIVE.md Step 5).
# Required for the folder-selection step at first-connect.
VITE_GOOGLE_API_KEY=
